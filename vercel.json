{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/products(.*)", "destination": "/api/index.js" },
    { "source": "/add-product", "destination": "/api/index.js" },
    { "source": "/buy/(.*)", "destination": "/api/index.js" },
    { "source": "/orders(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
